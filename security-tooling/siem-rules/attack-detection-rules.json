# Detection Rule: Process Injection (T1055)
POST _watcher/watch/t1055-process-injection
{
  "trigger": {
    "schedule": { "interval": "2m" }
  },
  "input": {
    "search": {
      "request": {
        "index": ["siem-*"],
        "body": {
          "query": {
            "bool": {
              "must": [
                { "match": { "tags": "process_access" } },
                { "range": { "@timestamp": { "gte": "now-2m" } } }
              ],
              "should": [
                { "match": { "source_process": "explorer.exe" } },
                { "match": { "source_process": "svchost.exe" } }
              ]
            }
          }
        }
      }
    }
  },
  "condition": {
    "compare": { "ctx.payload.hits.total.value": { "gt": 0 } }
  },
  "actions": {
    "log_alert": {
      "logging": {
        "text": "Process injection detected: {{ctx.payload.hits.hits.0}}"
      }
    }
  }
}
