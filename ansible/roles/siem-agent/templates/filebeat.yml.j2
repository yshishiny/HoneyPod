###################### Filebeat Configuration - HoneyPod Lab ######################
# Managed by Ansible — do not edit manually

filebeat.inputs:
  - type: log
    enabled: true
    paths:
      - /var/log/*.log
      - /var/log/syslog
      - /var/log/auth.log
    fields:
      lab_name: HoneyPod
      environment: cyber_range
      host_role: "{{ hostvars[inventory_hostname]['role'] | default('unknown') }}"
    fields_under_root: true

  - type: log
    enabled: true
    paths:
      - /var/log/honeypod/*.log
    fields:
      log_source: honeypod
      lab_name: HoneyPod
    fields_under_root: true

filebeat.config.modules:
  path: ${path.config}/modules.d/*.yml
  reload.enabled: false

setup.template.settings:
  index.number_of_shards: 1

output.logstash:
  hosts: ["{{ siem_server }}:5000"]

processors:
  - add_host_metadata:
      when.not.contains.tags: forwarded
  - add_cloud_metadata: ~
  - add_docker_metadata: ~
